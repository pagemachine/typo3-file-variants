{
	"name": "pagemachine/typo3-file-variants",
	"description": "Working prototype for translatable files in TYPO3",
	"license": "GPL-2.0+",
	"type": "typo3-cms-extension",
	"require": {
		"php": "^8.2",
		"psr/http-message": "^1.0 || ^2.0",
		"typo3/cms-backend": "^12.4 || ^13.4",
		"typo3/cms-core": "^12.4 || ^13.4",
		"typo3/cms-extbase": "^12.4 || ^13.4",
		"typo3/cms-fluid": "^12.4 || ^13.4",
		"typo3/cms-install": "^12.4 || ^13.4"
	},
	"require-dev": {
		"armin/editorconfig-cli": "^2.0",
		"ergebnis/composer-normalize": "^2.42",
		"friendsofphp/php-cs-fixer": "^3.0",
		"jangregor/phpstan-prophecy": "^1.0 || ^2.0",
		"phpspec/prophecy": "^1.19",
		"phpspec/prophecy-phpunit": "^2.2",
		"phpstan/extension-installer": "^1.3",
		"phpstan/phpstan": "^1.10 || ^2.0",
		"rector/rector": "^1.0 || ^2.0",
		"saschaegerer/phpstan-typo3": "^1.10 || ^3.0",
		"ssch/typo3-rector": "^2.2 || ^3.0",
		"typo3/coding-standards": "^0.8.0",
		"typo3/testing-framework": "^8.0 || ^9.0"
	},
	"replace": {
		"t3g/file-variants": "self.version",
		"t3g/file_variants": "self.version"
	},
	"autoload": {
		"psr-4": {
			"Pagemachine\\FileVariants\\": "Classes/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Pagemachine\\FileVariants\\Tests\\": "Tests/"
		}
	},
	"config": {
		"allow-plugins": {
			"ergebnis/composer-normalize": true,
			"phpstan/extension-installer": true,
			"typo3/class-alias-loader": true,
			"typo3/cms-composer-installers": true
		},
		"discard-changes": true,
		"sort-packages": true
	},
	"extra": {
		"typo3/cms": {
			"extension-key": "file_variants",
			"web-dir": "Build/Web"
		}
	},
	"scripts": {
		"build": [
			"@composer require --no-progress --ansi --update-with-dependencies typo3/cms-core $TYPO3_VERSION",
			"@lint",
			"@test"
		],
		"composer:lint": [
			"@composer validate --ansi",
			"@composer normalize --no-update-lock --dry-run"
		],
		"editorconfig:fix": [
			"ec --fix --no-progress --no-interaction"
		],
		"editorconfig:lint": [
			"ec --no-progress --no-interaction"
		],
		"lint": [
			"@composer:lint",
			"@php:static:lint",
			"@php:rector:lint",
			"@php:style:lint",
			"@editorconfig:lint"
		],
		"php:functional:tests": [
			"phpunit -c Build/FunctionalTests.xml"
		],
		"php:rector:fix": [
			"rector --config=Build/rector.php"
		],
		"php:rector:lint": [
			"rector --config=Build/rector.php --dry-run --no-progress-bar"
		],
		"php:static:lint": [
			"phpstan --configuration=Build/phpstan.neon analyse"
		],
		"php:style:fix": [
			"php-cs-fixer fix --config Build/.php-cs-fixer.dist.php"
		],
		"php:style:lint": [
			"php-cs-fixer check --config Build/.php-cs-fixer.dist.php --diff"
		],
		"php:unit:test": [
			"phpunit -c Build/UnitTests.xml"
		],
		"ter:deploy": [
			"git reset --hard",
			"git clean -xfd",
			"@composer global require typo3/tailor",
			"composer global exec -v -- tailor set-version $TAG",
			"composer global exec -v -- tailor ter:publish --comment \"$(git tag -l --format='%(contents)' $TAG)\" $TAG"
		],
		"test": [
			"@php:unit:test",
			"@php:functional:tests"
		]
	}
}
